# SEQUENCES FOR SLACK — RAILWAY SANDBOX VARIABLES
#
# Paste into Railway -> service -> Variables -> Raw Editor, then fill every
# uncommented value. These belong to the SANDBOX Slack app, never the normal
# development workspace app. After verification, seal credentials in Railway.
# See DEPLOYMENT.md and TESTING.md.
#
# Do not add:
#   SLACK_SIGNING_SECRET             Socket Mode does not use it
#   PORT                             Railway injects it
#   NODE_ENV / HOST                  Dockerfile supplies them
#   SLACK_SEQUENCES_DATA_DIR         Dockerfile sets /data
#   PUPPETEER_EXECUTABLE_PATH        Dockerfile sets the Chromium wrapper
#   PRODUCER_LOW_MEMORY_MODE         Dockerfile supplies it

# Explicit Dockerfile selection. This is a safe fallback if Railway does not
# apply the checked-in railway.json during initial service creation.
RAILWAY_DOCKERFILE_PATH=Dockerfile

# Sandbox Slack app tokens.
SLACK_BOT_TOKEN=xoxb-...
SLACK_APP_TOKEN=xapp-...

# Sandbox Slack app credentials from Basic Information.
SLACK_CLIENT_ID=...
SLACK_CLIENT_SECRET=...

# Public URL of this Railway service, without a trailing slash. The redirect URI
# must be added verbatim under Slack -> OAuth & Permissions -> Redirect URLs.
PUBLIC_BASE_URL=https://YOUR-SERVICE.up.railway.app
SLACK_REDIRECT_URI=https://YOUR-SERVICE.up.railway.app/slack/oauth_redirect

# Generate each independently:
# node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
SLACK_STATE_SECRET=...
SLACK_TOKEN_ENCRYPTION_KEY=...

# Slack hosted-MCP retrieval. Required for real /sequences, not for the demo.
# Use a dedicated OpenAI project key with conservative model/rate limits.
OPENAI_API_KEY=sk-...
# SLACK_MCP_CONTEXT_MODEL=gpt-5-mini

# Planning provider: use ONE option. (This is ONLY the planning brain. Slack
# hosted-MCP context retrieval above always needs OPENAI_API_KEY — it uses the
# OpenAI Responses API `mcp` tool type, which OpenRouter/DeepSeek do not support.)
#
# Option A — OpenRouter gateway (one key → DeepSeek, GLM, etc. — cheap):
SLACK_SEQUENCES_PROVIDER=openrouter-api
OPENROUTER_API_KEY=sk-or-v1-...
# SEQUENCES_OPENROUTER_MODEL=deepseek/deepseek-v4-pro
# SLACK_SEQUENCES_LIGHT_MODEL=deepseek/deepseek-v4-flash # cheap tier for the small
#   optional art-direction JSON decision. Heavy composition authoring stays on
#   the primary model above. Defaults to Flash only where deterministic fallback is safe.
# SLACK_SEQUENCES_STORYBOARD_MODEL=z-ai/glm-5.2 # OpenRouter default when unset:
#   one reasoning-enabled call for the high-leverage cut/storyboard decision.
#   Set "primary" to keep this pass on SEQUENCES_OPENROUTER_MODEL instead.
# SLACK_SEQUENCES_REPAIR_MODEL=... # optional explicit override for bounded exact
# patch repairs. Unset keeps structural repairs on the primary DeepSeek model;
# OpenAI is never selected implicitly. Cursor endpoints/ripples are repaired by
# deterministic geometry and normally need no repair-model call.
#   Patch calls only. Full-document recovery always stays on the primary model.
# SLACK_SEQUENCES_INTERACTION_QA=enforce # default. Persistently invalid optional
#   interactions are isolated individually after bounded repair; runtime health
#   stays enforced and the rest of the film is never discarded.
# SEQUENCES_MAX_OUTPUT_TOKENS=10240  # output-token ceiling for the composition author.
#   Authoring explicitly disables model reasoning so this budget is reserved for
#   the actual HTML. OpenRouter retains and continues partial source when a route
#   reaches this ceiling. Exact repair patches use a fixed 4096-token ceiling,
#   native JSON schema, and keep their existing validated scratch.
#
# Option B — reuse OpenAI temporarily:
# SLACK_SEQUENCES_PROVIDER=openai-api
# SEQUENCES_OPENAI_MODEL=gpt-5-mini
#
# Option C — dedicated Anthropic workspace key with a low spend limit:
# SLACK_SEQUENCES_PROVIDER=anthropic-api
# ANTHROPIC_API_KEY=sk-ant-...
# SEQUENCES_ANTHROPIC_MODEL=claude-sonnet-4-6
