# ─── Sequences for Slack — Railway variables ────────────────────────────────
# Paste into Railway → your service → Variables → "Raw Editor", then fill every
# value. These names MUST match the code exactly.
#
# NOT NEEDED (don't add them):
#   • SLACK_SIGNING_SECRET — Socket Mode doesn't use it.
#   • PORT — Railway injects it; the app reads process.env.PORT.
#   • NODE_ENV / HOST / SLACK_SEQUENCES_DATA_DIR / PUPPETEER_EXECUTABLE_PATH /
#     PRODUCER_LOW_MEMORY_MODE — already baked into the Dockerfile.

# ── Slack sandbox app: Socket Mode tokens ──
# Bot token: OAuth & Permissions → Bot User OAuth Token (re-copy after any reinstall).
SLACK_BOT_TOKEN=xoxb-...
# App-level token: Basic Information → App-Level Tokens (scope: connections:write).
SLACK_APP_TOKEN=xapp-...

# ── Slack sandbox app: OAuth credentials (Basic Information → App Credentials) ──
SLACK_CLIENT_ID=...
SLACK_CLIENT_SECRET=...

# ── Public URL of THIS Railway service (no trailing slash) + matching redirect ──
# SLACK_REDIRECT_URI must be added verbatim under OAuth & Permissions → Redirect URLs.
PUBLIC_BASE_URL=https://YOUR-SERVICE.up.railway.app
SLACK_REDIRECT_URI=https://YOUR-SERVICE.up.railway.app/slack/oauth_redirect

# ── Two independent 32-byte secrets. Generate EACH separately with: ──
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
SLACK_STATE_SECRET=...
SLACK_TOKEN_ENCRYPTION_KEY=...

# ── Slack hosted-MCP workspace retrieval (OpenAI Responses API remote MCP) ──
# REQUIRED for the real /sequences create flow. The /sequences demo path does NOT need it.
OPENAI_API_KEY=sk-...
# SLACK_MCP_CONTEXT_MODEL=gpt-5-mini

# ── Planning brain. In a container use the API provider (no interactive CLI). ──
SLACK_SEQUENCES_PROVIDER=anthropic-api
ANTHROPIC_API_KEY=sk-ant-...
# SEQUENCES_ANTHROPIC_MODEL=claude-sonnet-4-6
