# SEQUENCES FOR SLACK — RAILWAY SANDBOX VARIABLES
#
# Paste into Railway -> service -> Variables -> Raw Editor, then fill every
# uncommented value. These belong to the SANDBOX Slack app, never the normal
# development workspace app. After verification, seal credentials in Railway.
# See CLAUDE.md and OPERATIONS.md.
#
# Do not add:
#   SLACK_SIGNING_SECRET             Socket Mode does not use it
#   PORT                             Railway injects it for sequences-slack;
#                                    codex-worker sets 3000 for private routing
#   NODE_ENV / HOST                  Dockerfile supplies them
#   SLACK_SEQUENCES_DATA_DIR         Dockerfile sets /data
#   PUPPETEER_EXECUTABLE_PATH        Dockerfile sets the Chromium wrapper
#   PRODUCER_LOW_MEMORY_MODE         Dockerfile supplies it

# Explicit Dockerfile selection. This is a safe fallback if Railway does not
# apply the checked-in railway.json during initial service creation.
RAILWAY_DOCKERFILE_PATH=Dockerfile

# Sandbox Slack app tokens.
SLACK_BOT_TOKEN=xoxb-...
SLACK_APP_TOKEN=xapp-...

# Sandbox Slack app credentials from Basic Information.
SLACK_CLIENT_ID=...
SLACK_CLIENT_SECRET=...

# Public URL of this Railway service, without a trailing slash. The redirect URI
# must be added verbatim under Slack -> OAuth & Permissions -> Redirect URLs.
PUBLIC_BASE_URL=https://YOUR-SERVICE.up.railway.app
SLACK_REDIRECT_URI=https://YOUR-SERVICE.up.railway.app/slack/oauth_redirect

# Generate each independently:
# node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
SLACK_STATE_SECRET=...
SLACK_TOKEN_ENCRYPTION_KEY=...

# Slack hosted-MCP retrieval. Required for real /sequences, not for the demo.
# Use a dedicated OpenAI project key with conservative model/rate limits.
OPENAI_API_KEY=sk-...
# SLACK_MCP_CONTEXT_MODEL=gpt-5-mini

# Default video author: private codex-worker service. Railway expands the
# service-reference expressions below. Set the same independent 32+ character
# token as LUNA_WORKER_TOKEN on codex-worker; never print it in logs.
SLACK_SEQUENCES_AUTHOR_ROUTE=luna-direct
SLACK_SEQUENCES_LUNA_WORKER_URL=http://${{codex-worker.RAILWAY_PRIVATE_DOMAIN}}:${{codex-worker.PORT}}
SLACK_SEQUENCES_LUNA_WORKER_TOKEN=...
SLACK_SEQUENCES_LUNA_JOB_TIMEOUT_MS=1800000

# codex-worker service variables (set on that service, not sequences-slack):
# PORT=3000
# LUNA_WORKER_TOKEN=<same secret>
# LUNA_MODEL=gpt-5.6-sol
# LUNA_REASONING_EFFORT=high
# LUNA_JOB_TIMEOUT_MS=1800000
# LUNA_MAX_QUEUE_DEPTH=4
# LUNA_MAX_WORKSPACE_BYTES=134217728
# LUNA_MIN_FREE_BYTES=536870912
# CODEX_HOME=/root/.codex  # persistent Railway volume containing auth.json

# Explicit emergency rollback only. A failed Luna job never selects this route.
# Re-add the provider credential only while rollback is intentionally active.
# SLACK_SEQUENCES_AUTHOR_ROUTE=legacy-provider
# SLACK_SEQUENCES_PROVIDER=openrouter-api
# OPENROUTER_API_KEY=sk-or-v1-...
# Explicit proof-film drill only; ordinary creates fail loud by default.
# SLACK_SEQUENCES_ALLOW_DETERMINISTIC_FALLBACK=1
