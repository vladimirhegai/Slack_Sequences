{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["decision", "baseFingerprint", "files"],
  "properties": {
    "decision": {
      "type": "string",
      "enum": ["keep", "replace"]
    },
    "baseFingerprint": {
      "type": ["string", "null"],
      "pattern": "^[a-f0-9]{64}$"
    },
    "files": {
      "type": "array",
      "maxItems": 128,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "action", "content", "copyFromInput", "sha256"],
        "properties": {
          "path": {
            "type": "string",
            "minLength": 1,
            "maxLength": 240,
            "pattern": "^deliverables/[A-Za-z0-9._/-]+$"
          },
          "action": {
            "type": "string",
            "enum": ["inherit", "replace"]
          },
          "content": {
            "type": ["string", "null"]
          },
          "copyFromInput": {
            "type": ["string", "null"],
            "minLength": 1,
            "maxLength": 240,
            "pattern": "^inputs/[A-Za-z0-9._/-]+$"
          },
          "sha256": {
            "type": ["string", "null"],
            "pattern": "^[a-f0-9]{64}$"
          }
        }
      }
    }
  }
}
