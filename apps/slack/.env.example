# Slack app credentials — copy to apps/slack/.env and fill in.
# .env is gitignored; never commit real tokens.

# Bot User OAuth token (xoxb-...) from your app's OAuth & Permissions page.
SLACK_BOT_TOKEN=xoxb-your-bot-token

# App-Level token (xapp-...) with connections:write, for Socket Mode.
SLACK_APP_TOKEN=xapp-your-app-token
