# LOCAL development credentials.
# Copy to apps/slack/.env (gitignored) and fill in.
# These values belong to the Slack app installed in your NORMAL WORKSPACE.
# Never put the separate sandbox/Railway app's xoxb/xapp tokens here.
# See CLAUDE.md and OPERATIONS.md.

# Required for the model-free /sequences demo and normal Socket Mode operation.
SLACK_BOT_TOKEN=xoxb-your-local-workspace-bot-token
SLACK_APP_TOKEN=xapp-your-local-workspace-app-token

# Required for the real /sequences flow. Use the public HTTPS URL of the local
# tunnel. SLACK_REDIRECT_URI must exactly match a Redirect URL in the local Slack
# app settings.
# SLACK_CLIENT_ID=your-local-app-client-id
# SLACK_CLIENT_SECRET=your-local-app-client-secret
# PUBLIC_BASE_URL=https://your-local-tunnel.example
# SLACK_REDIRECT_URI=https://your-local-tunnel.example/slack/oauth_redirect

# Generate each value independently:
# node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# SLACK_STATE_SECRET=replace-with-an-independent-random-secret
# SLACK_TOKEN_ENCRYPTION_KEY=replace-with-an-independent-base64-32-byte-key

# Required for Slack hosted-MCP retrieval in the real create flow. Requests are
# billed to this account; use a dedicated OpenAI project key with conservative
# model/rate limits.
# OPENAI_API_KEY=sk-your-openai-project-key
# SLACK_MCP_CONTEXT_MODEL=gpt-5-mini

# Luna direct is the default author route. Run apps/slack/codex-worker against a
# dedicated logged-in CODEX_HOME, then give both processes the same independent
# 32+ character bearer secret. The model and high reasoning are pinned by the
# worker; no OpenRouter or model API key belongs in the Slack process.
# SLACK_SEQUENCES_AUTHOR_ROUTE=luna-direct
# SLACK_SEQUENCES_LUNA_WORKER_URL=http://127.0.0.1:3000
# SLACK_SEQUENCES_LUNA_WORKER_TOKEN=replace-with-an-independent-random-secret
# SLACK_SEQUENCES_LUNA_JOB_TIMEOUT_MS=1800000

# Explicit rollback only. The complete former provider committee is preserved,
# but Luna failures never enter it automatically.
# SLACK_SEQUENCES_AUTHOR_ROUTE=legacy-provider
# SLACK_SEQUENCES_PROVIDER=anthropic-api
# ANTHROPIC_API_KEY=sk-ant-...
# SEQUENCES_ANTHROPIC_MODEL=claude-sonnet-4-6

# Live create/revise/preview/render uses the internal Sequences MCP server by
# default. Set this to 0 only to diagnose the in-process fallback.
# SLACK_SEQUENCES_USE_MCP=0

# Explicit proof-film drill only. Ordinary Luna and legacy creates fail visibly
# by default; set to 1 only when an operator deliberately wants the labeled
# model-free proof output.
# SLACK_SEQUENCES_ALLOW_DETERMINISTIC_FALLBACK=1

# Local default: apps/slack/.data
# SLACK_SEQUENCES_DATA_DIR=
