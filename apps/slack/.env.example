# LOCAL dev credentials — copy to apps/slack/.env and fill in (gitignored).
# Use your normal *workspace* Slack app tokens here. For the Railway *sandbox*
# deployment, use apps/slack/.env.railway.example instead (set in the Railway
# dashboard, not committed). See DEPLOYMENT.md.
#
# `/sequences demo` works locally with just the two SLACK_*_TOKEN values below.
# The full `/sequences` create flow additionally needs the OAuth + provider keys
# further down (and a public callback URL — i.e. Railway, or a tunnel).

# Bot User OAuth token (xoxb-...) from your app's OAuth & Permissions page.
SLACK_BOT_TOKEN=xoxb-your-bot-token

# App-Level token (xapp-...) with connections:write, for Socket Mode.
SLACK_APP_TOKEN=xapp-your-app-token

# Per-user OAuth for Slack's hosted MCP server.
SLACK_CLIENT_ID=your-client-id
SLACK_CLIENT_SECRET=your-client-secret
PUBLIC_BASE_URL=https://your-service.up.railway.app
SLACK_REDIRECT_URI=https://your-service.up.railway.app/slack/oauth_redirect
# Generate each independently; see DEPLOYMENT.md.
SLACK_STATE_SECRET=replace-with-a-random-secret
SLACK_TOKEN_ENCRYPTION_KEY=replace-with-a-base64-encoded-32-byte-key

# Slack workspace context is retrieved with the OpenAI Responses API's remote
# MCP support. This can be independent of the video planning provider below.
OPENAI_API_KEY=sk-your-openai-key
# SLACK_MCP_CONTEXT_MODEL=gpt-5-mini

# Planning brain (optional). Default tries claude-code-cli (no key), then anthropic-api.
# SLACK_SEQUENCES_PROVIDER=anthropic-api
# ANTHROPIC_API_KEY=sk-ant-...
# SEQUENCES_ANTHROPIC_MODEL=claude-sonnet-4-6

# Live create/revise/preview/render uses the Sequences MCP server by default.
# Set to 0 only to force the diagnostic in-process path.
# SLACK_SEQUENCES_USE_MCP=0

# Override where per-project workspaces live (default: apps/slack/.data).
# SLACK_SEQUENCES_DATA_DIR=
